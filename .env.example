# Copy to .env and adjust. All values are optional.

# The URL the Connext platform uses to reach this server. Every OAuth endpoint
# advertised in the discovery documents is built from this, so it must be the
# real, publicly reachable URL in production (e.g. https://product-studio.example.com).
# For local development the default is fine.
PUBLIC_URL=http://localhost:8000

# Where uvicorn binds. Use 0.0.0.0 to accept connections from other machines.
HOST=127.0.0.1
PORT=8000
